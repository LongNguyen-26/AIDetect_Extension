{
  "manifest_version": 3,
  "name": "AIDetect Admin - Group Post Review",
  "short_name": "AIDetect",
  "version": "1.1.0",
  "description": "Detects AI-generated content in Facebook group posts waiting for admin approval through the AIDetect backend.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.facebook.com/groups/*",
    "https://facebook.com/groups/*",
    "https://aidetect-web.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AIDetect Admin"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/groups/*",
        "https://facebook.com/groups/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
